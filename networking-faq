<script>
/* ─── TOGGLE SINGLE ITEM ─── */
function toggleItem(el) {
  el.classList.toggle('is-open');
}

/* ─── EXPAND / COLLAPSE SECTION ─── */
function expandSection(sId) {
  document.getElementById('list-' + sId)
    .querySelectorAll('.qa-item')
    .forEach(function(item) { item.classList.add('is-open'); });
}
function collapseSection(sId) {
  document.getElementById('list-' + sId)
    .querySelectorAll('.qa-item')
    .forEach(function(item) { item.classList.remove('is-open'); });
}

/* ─── SEARCH / FILTER ─── */
function filterQA(query) {
  var q = query.trim().toLowerCase();
  document.querySelectorAll('.qa-item').forEach(function(item) {
    if (!q) {
      item.classList.remove('hidden');
      return;
    }
    var text = item.textContent.toLowerCase();
    if (text.indexOf(q) !== -1) {
      item.classList.remove('hidden');
      item.classList.add('is-open');
    } else {
      item.classList.add('hidden');
    }
  });
}
</script>

